# ====================
# Database Configuration
# ====================
# SQLite (default)
DATABASE_URL=sqlite:///data/crawler.db

# Supabase (PostgreSQL cloud database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_KEY=your_anon_key_here

# ====================
# Vector Store (Pinecone)
# ====================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=crawler-articles
PINECONE_ENVIRONMENT=us-east-1-aws
EMBEDDING_DIMENSION=1536

# ====================
# AI / ML APIs
# ====================
# Get ZhipuAI key from: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=
ZHIPU_MODEL=glm-4

# Get DeepSeek key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen Embedding (DashScope)
DASHSCOPE_API_KEY=
EMBEDDING_MODEL=text-embedding-v2

# AI Classification Settings
AI_CLASSIFIER_MODEL=deepseek  # Options: zhipu, deepseek

# ====================
# Dify Integration
# ====================
DIFY_API_KEY=
DIFY_BASE_URL=https://api.dify.ai
DIFY_DATASET_ID=

# ====================
# Platform Cookies (use dedicated test accounts only!)
# ====================
# Zhihu Cookie - Get from browser after logging in with a TEST account
# ⚠️ WARNING: Use a dedicated test account, NEVER use your main account!
# Instructions:
# 1. Login to Zhihu in browser (use a test account only!)
# 2. Open DevTools (F12) → Application → Cookies → zhihu.com
# 3. Copy all cookies as: name1=value1; name2=value2; name3=value3
# 4. Set the variable below (DO NOT commit your actual cookies!)
ZHIHU_COOKIE=

# ====================
# Proxy Configuration
# ====================
PROXY_ENABLED=false
PROXY_API_URL=

# ====================
# Application Settings
# ====================
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000

# Use FastAPI instead of Flask (set to "true" to use FastAPI)
USE_FASTAPI=false

# ====================
# Scheduler Settings
# ====================
SCHEDULER_TIMEZONE=Asia/Shanghai
